# Copy this file to .env and fill in real values. Never commit .env itself.

# LLM provider (Gemini used by default; swap in llm_service.py if you prefer another provider)
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL=gemini-1.5-flash

# Database
DATABASE_URL=sqlite:///./database/dreambridge.db

# File storage
UPLOAD_DIR=./storage/uploads

# CORS - comma separated origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
